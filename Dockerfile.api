# Dockerfile.api — DGX Spark Production (Blackwell / CUDA 13)
FROM nvidia/cuda:13.0.2-runtime-ubuntu22.04

WORKDIR /app

# System deps for OCR fallback, PDF processing, and PostgreSQL
RUN apt-get update && apt-get install -y \
    python3.11 python3.11-venv python3-pip \
    tesseract-ocr libtesseract-dev poppler-utils \
    gcc libpq-dev curl \
    libgl1-mesa-glx libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.11 /usr/bin/python3

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# OpenAI + httpx for remote LLM/Embedding calls
RUN pip install --no-cache-dir openai httpx

COPY . .

# Production: multiple workers for concurrency
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4"]
