# Dockerfile.api — DGX Spark Production (Blackwell / CUDA 13)
FROM nvidia/cuda:13.0.2-runtime-ubuntu22.04

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UVICORN_WORKERS=1

# System deps for OCR fallback, PDF processing, and PostgreSQL
RUN apt-get update && apt-get install -y \
    python3.11 python3.11-venv python3-pip \
    tesseract-ocr tesseract-ocr-ara tesseract-ocr-fra tesseract-ocr-eng \
    libtesseract-dev poppler-utils \
    gcc libpq-dev curl \
    libgl1-mesa-glx libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.11 /usr/bin/python3

RUN python3.11 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN python -m pip install --no-cache-dir --upgrade pip

COPY requirements.txt .
RUN python -m pip install --no-cache-dir -r requirements.txt

# OpenAI + httpx for remote LLM/Embedding calls
RUN python -m pip install --no-cache-dir openai httpx

COPY . .

# Default to a single worker because upload/query load model state and run
# background tasks inside the API container. Scale only after validating
# memory usage and model warmup behavior in production.
CMD ["sh", "-c", "python -m uvicorn api.main:app --host 0.0.0.0 --port 8000 --workers ${UVICORN_WORKERS}"]
