# ── Tunisie Electronique RAG — Environment Configuration Template ──

APP_ENV_FILE=.env.local

# Auth (CHANGE THIS in production — generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production-random-string

# Database (SQLite for local dev, PostgreSQL for DGX Spark)
DATABASE_URL=sqlite+aiosqlite:///./enterprise_rag.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/rag_enterprise

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_docs

# LLM
LLM_MODEL=qwen3:4b-instruct
LLM_BASE_URL=http://localhost:11434/v1
CONTEXT_LIMIT=8192

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
TEI_URL=http://localhost:8002

# CORS (React dev server)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
